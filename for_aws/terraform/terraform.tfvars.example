# プロジェクトの基本設定
project_name   = "yahoo-cru-bourgeois"
environment    = "dev"
s3_bucket_name = "your-unique-bucket-name-here" # 世界で一意な名前に変更してください

# Yahoo! API キー (必須)
yahoo_api_key = "your-yahoo-application-id-here"

# 定期実行スケジュール (オプション: デフォルトは毎週金曜)
# schedule_expression = "cron(0 0 ? * 5 *)"

# --- カスタムドメイン設定 (オプション) ---
# Route 53 でドメインを管理しており、ACM証明書を取得済みの場合に設定
# custom_domain_name   = "api.yourdomain.com"
# route53_zone_id      = "Z0123456789ABCDEFGHIJ"
# acm_certificate_arn  = "arn:aws:acm:ap-northeast-1:123456789012:certificate/xxxx-xxxx-xxxx"
